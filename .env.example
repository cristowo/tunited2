# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIAR_password_seguro_32_chars_min
POSTGRES_AUTH_DB=auth_db
POSTGRES_MAIN_DB=main_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Usuario de aplicación (no-superuser, sujeto a RLS) — ver db/init/04-rls.sql
POSTGRES_APP_SERVICE_USER=app_service
POSTGRES_APP_SERVICE_PASSWORD=CAMBIAR_password_app_service

# JWT — usar valores aleatorios de 64+ caracteres (openssl rand -base64 64)
JWT_SECRET=CAMBIAR_generar_con_openssl_rand
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CAMBIAR_generar_con_openssl_rand
JWT_REFRESH_EXPIRES_IN=7d

# Secreto compartido entre api-gateway y main-service para firmar x-user-id/
# x-user-role en requests admin — evita que alcanzar main-service directo
# (sin pasar por el gateway) sea suficiente para obtener acceso admin.
INTERNAL_AUTH_SECRET=CAMBIAR_generar_con_openssl_rand

# RabbitMQ — cambiar credenciales por defecto
RABBITMQ_URL=amqp://mudanzas_user:CAMBIAR_password@localhost:5672
RABBITMQ_USER=mudanzas_user
RABBITMQ_PASS=CAMBIAR_password

# Redis (rate limiting compartido del gateway) — incluir la contraseña en la URL
REDIS_PASSWORD=CAMBIAR_password_redis
REDIS_URL=redis://:CAMBIAR_password_redis@localhost:6379

# Email
# Aviso de cotizaciones nuevas al equipo + URL del panel para los enlaces
ADMIN_EMAIL=ventas@tunited.cl
ADMIN_PANEL_URL=http://localhost:5173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@email.com
SMTP_PASS=CAMBIAR_app_password

# Puertos
GATEWAY_PORT=3000
AUTH_PORT=3001
MAIN_PORT=3002

# Entorno — en 'production' el CAPTCHA es obligatorio (no se puede omitir)

# Retención de datos (Ley 21.719): meses tras los cuales se purgan las
# cotizaciones canceladas. Vacío o 0 = purga desactivada.
RETENTION_MONTHS=12
NODE_ENV=production

# CORS — origen(es) permitidos del frontend (separar múltiples con coma sin espacios)
# Producción: CORS_ORIGIN=https://unitedmudanzas.cl,https://www.unitedmudanzas.cl
CORS_ORIGIN=http://localhost,http://localhost:5173

# reCAPTCHA v2 — obtener en https://www.google.com/recaptcha/admin
VITE_RECAPTCHA_SITE_KEY=TU_SITE_KEY
RECAPTCHA_SECRET_KEY=TU_SECRET_KEY

# Nota: el número de WhatsApp, dirección, redes sociales, etc. del landing ya
# no se configuran aquí — son editables desde el panel admin (/admin/contenido).
